# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ───────────────────────────────────────────────────────────────
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dbname
# MongoDB Local: mongodb://127.0.0.1:27017/hackfusion-2k26
MONGODB_URI=mongodb://127.0.0.1:27017/hackfusion-2k26

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret_here_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
# Model used for chat and TTS (gpt-4o recommended for agent tool calls)
OPENAI_MODEL=gpt-4o
# TTS voice (alloy, echo, fable, onyx, nova, shimmer)
TTS_VOICE=nova

# ─── Cloudinary (Prescription image upload) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Refill Alerts / Notifications) ──────────────────────────────────
# Using Resend (recommended) or SendGrid
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourpharmacy.ai

# ─── Feature Flags ──────────────────────────────────────────────────────────
# Set to 'true' to enable SSE streaming chat responses
ENABLE_SSE_STREAMING=true
# Set to 'true' to log all agent runs to MongoDB AgentAuditLog collection
ENABLE_AUDIT_LOG=true

# ─── Frontend (Vite) — copy to frontend/.env ────────────────────────────────
# VITE_API_URL=http://localhost:5000/api

# ─── Twilio (WhatsApp Notifications) ────────────────────────────────────────
# Sign up at https://twilio.com → Get Account SID & Auth Token from Console
# For sandbox testing: send "join <keyword>" to +14155238886 on WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Sandbox number (default). For production, use your approved WhatsApp Business number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
