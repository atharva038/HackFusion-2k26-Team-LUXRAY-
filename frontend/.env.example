# Local development (Vite proxy handles /api → localhost:5000)
# Leave empty or don't set — it defaults to /api
# VITE_API_URL=/api

# Production — set this to your deployed backend URL
# Example: VITE_API_URL=https://your-backend.onrender.com/api

# Optional explicit socket endpoint (if different from VITE_API_URL without /api)
# Example: VITE_SOCKET_URL=https://your-backend.onrender.com
